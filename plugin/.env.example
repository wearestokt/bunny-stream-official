# -----------------------------------------------------------------------------
# Default (recommended for users): hosted components only — NO source files are
# copied into Framer projects. Paste each component’s “Copy URL” from Assets →
# Code Components after publishing those components (same account / team).
# Build the plugin with these set (e.g. CI env) before `npm run pack`.
# -----------------------------------------------------------------------------
VITE_STREAM_BUNNY_EMBED_SOURCES=false

# IMPORTANT: quote each value. dotenv strips an unquoted `#fragment`, which would
# remove the `#ExportName` Framer needs to load the right named export.
VITE_SB_MODULE_BunnyVideoPlayer="https://framer.com/m/BunnyVideoPlayer-XXXXXX.js@XXXXXXXXXXXXXXXXXXXX#BunnyVideoPlayer"
VITE_SB_MODULE_BunnyPlayPauseButton=""
VITE_SB_MODULE_BunnyVolumeSlider=""
VITE_SB_MODULE_BunnyProgressBar=""
VITE_SB_MODULE_BunnyTimeDisplay=""
VITE_SB_MODULE_BunnyQualityPickerButton=""
VITE_SB_MODULE_BunnyFullscreenButton=""

# Published library utility (code override — not draggable from the palette)
# Not required for local plugin dev: `npm run dev` embeds BunnyIdleFade.tsx automatically.
VITE_SB_MODULE_BunnyIdleFade=""

# Force off local embed in dev (test hosted re-export). Omit or "true" to embed in dev.
# VITE_STREAM_BUNNY_EMBED_SOURCES=false

# Store module URL (used by draggable components; not required for idle fade)
VITE_SB_MODULE_BunnyVideoStore=""

# -----------------------------------------------------------------------------
# Templates (optional). Each template is a pre-composed component published in
# the same upstream Stream Bunny library project. Plugin boots even when these
# are blank — the Templates screen falls back to a "coming soon" notify (or, for
# Cinema Hero, the legacy multi-component bundle insert).
# Paste each template’s “Copy URL” from Assets → Code Components after publishing.
# -----------------------------------------------------------------------------
# VITE_SB_MODULE_BunnyTemplateCinemaHero=""
# VITE_SB_MODULE_BunnyTemplatePressReel=""
# VITE_SB_MODULE_BunnyTemplateStoryTile=""
# VITE_SB_MODULE_BunnyTemplateWallStack=""
# VITE_SB_MODULE_BunnyTemplateTutorialRow=""
# VITE_SB_MODULE_BunnyTemplateShowcaseStrip=""

# -----------------------------------------------------------------------------
# Maintainers only: inject raw `.tsx` from this repo into the open Framer project.
# Optional alternative to setting every VITE_SB_MODULE_* above. Never ship marketplace builds with this.
# -----------------------------------------------------------------------------
# VITE_STREAM_BUNNY_EMBED_SOURCES=true

# -----------------------------------------------------------------------------
# Pro / Polar (optional for local dev — use regex-only unlock without these)
# -----------------------------------------------------------------------------
# Absolute URL of the deployed license API (see repo /api/license/validate.ts)
# VITE_LICENSE_VALIDATE_URL="https://your-project.vercel.app/api/license/validate"
# Polar product checkout (Buy on Polar button)
# VITE_POLAR_CHECKOUT_URL="https://polar.sh/your-org/checkout/…"
# Dashboard → tutorial dialog (MP4 or other URL supported by <video>)
# VITE_TUTORIAL_VIDEO_URL="https://…/walkthrough.mp4"
# User-facing documentation (Help → Documentation). Enable GitHub Pages from /docs, then set:
# VITE_DOCS_URL="https://wearestokt.github.io/bunny-stream-official/"
# VITE_CHANGELOG_URL="https://github.com/wearestokt/bunny-stream-official/blob/main/CHANGELOG.md"
# VITE_FEATURE_REQUEST_URL="https://github.com/…/issues"
